@page
@model IndexModel
@{
    ViewData["Title"] = "EduChatbot Product Group";
}

<section class="workspace">
    <div class="topbar">
        <div>
            <p class="eyebrow">03 Product Group</p>
            <h1>EduChatbot AI</h1>
            <p>Ban ProductGroup dung Razor Pages, giu chuc nang chatbot va them dashboard van hanh cho demo nhom.</p>
        </div>
        <div class="actions">
            <a class="secondary" asp-page="/Dashboard">Dashboard</a>
            <a class="primary" asp-page="/Subjects/Index">Quan ly mon</a>
        </div>
    </div>

    <div class="subject-grid">
        @foreach (var subject in Model.Subjects)
        {
            var indexed = subject.Documents?.Count(d => d.IsIndexed) ?? 0;
            var total = subject.Documents?.Count ?? 0;
            <article class="subject-card">
                <div>
                    <span class="code">@subject.Code</span>
                    <h2>@subject.Name</h2>
                    <p>@indexed/@total tai lieu da index</p>
                </div>
                <a asp-page="/Chat/Index" asp-route-subjectId="@subject.Id">Mo chatbot</a>
            </article>
        }
    </div>
</section>

