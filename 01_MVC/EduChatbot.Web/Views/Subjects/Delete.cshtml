@model EduChatbot.Web.Models.Subject

@{
    ViewData["Title"] = "Xóa Môn học";
}

<h1>Xóa Môn học</h1>

<h3>Bạn có chắc chắn muốn xóa môn học này không?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">Mã môn học</dt>
        <dd class = "col-sm-10">@Html.DisplayFor(model => model.Code)</dd>
        <dt class = "col-sm-2">Tên môn học</dt>
        <dd class = "col-sm-10">@Html.DisplayFor(model => model.Name)</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Xóa vĩnh viễn" class="btn btn-danger" /> |
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </form>
</div>
