@model IEnumerable<EduChatbot.Web.Models.Document>

@{
    ViewData["Title"] = "Quản lý Tài liệu";
}

<h1>Danh sách Tài liệu (Documents)</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Upload Tài liệu mới</a>
</p>
<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Tên file</th>
            <th>Môn học</th>
            <th>Ngày Upload</th>
            <th>Trạng thái Index AI</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                <a href="@item.FilePath" target="_blank">@item.FileName</a>
            </td>
            <td>@(item.Subject?.Name ?? "N/A") (@(item.Subject?.Code ?? "N/A"))</td>
            <td>@item.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
            <td>
                @if (item.IsIndexed)
                {
                    <span class="badge bg-success">Đã Index</span>
                    <span class="text-muted small">@item.ChunkCount đoạn</span>
                }
                else if (item.IndexStatus == "Failed")
                {
                    <span class="badge bg-danger" title="@item.IndexMessage">Lỗi Index</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Chưa Index</span>
                }
            </td>
            <td>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Xóa</a>
            </td>
        </tr>
}
    </tbody>
</table>
