@model IEnumerable<EduChatbot.Web.Models.Subject>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EduChatbot - Hệ thống hỏi đáp thông minh</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        * { box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: #0f0f11; color: #e8eaed; margin: 0; min-height: 100vh; }
        
        /* Top Bar */
        .topbar { padding: 16px 5%; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #2a2a2e; }
        .logo { font-size: 1.3rem; font-weight: 600; color: #e8eaed; text-decoration: none; display: flex; align-items: center; gap: 10px; }
        .logo-icon { width: 36px; height: 36px; background: linear-gradient(135deg, #667eea, #764ba2); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; }
        
        /* Hero */
        .hero { text-align: center; padding: 60px 5% 40px; }
        .hero h1 { font-size: 2.2rem; font-weight: 700; margin-bottom: 12px; }
        .hero h1 span { background: linear-gradient(90deg, #667eea, #764ba2); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .hero p { color: #9aa0a6; font-size: 1.05rem; max-width: 600px; margin: 0 auto 30px; line-height: 1.6; }
        
        /* Feature Pills */
        .features { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; margin-bottom: 50px; padding: 0 5%; }
        .feat-pill { background: #1a1a1e; border: 1px solid #2a2a2e; border-radius: 20px; padding: 8px 18px; font-size: 0.82rem; color: #9aa0a6; display: flex; align-items: center; gap: 7px; }
        .feat-pill i { color: #667eea; }
        
        /* Cards Grid */
        .cards-section { padding: 0 5% 60px; }
        .cards-section h2 { font-size: 1.2rem; font-weight: 500; margin-bottom: 24px; color: #9aa0a6; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }
        
        .card-nb { background: #1a1a1e; border: 1px solid #2a2a2e; border-radius: 16px; padding: 24px; display: flex; flex-direction: column; gap: 16px; text-decoration: none; color: #e8eaed; transition: all 0.25s; cursor: pointer; }
        .card-nb:hover { border-color: #667eea; transform: translateY(-3px); box-shadow: 0 8px 30px rgba(102,126,234,0.15); color: #e8eaed; }
        .card-nb-create { border-style: dashed; align-items: center; justify-content: center; min-height: 160px; }
        .card-nb-create:hover { background: rgba(102,126,234,0.05); }
        
        .card-icon { width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, #667eea20, #764ba220); border: 1px solid #667eea40; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; color: #667eea; }
        .card-title { font-size: 1.1rem; font-weight: 600; }
        .card-meta { font-size: 0.8rem; color: #9aa0a6; display: flex; gap: 16px; }
        .card-meta span { display: flex; align-items: center; gap: 5px; }
        
        .plus-icon { width: 56px; height: 56px; border-radius: 50%; background: #2a2a2e; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; color: #667eea; margin-bottom: 8px; }
        
        /* Modal */
        .modal-content { background: #1a1a1e; color: #e8eaed; border: 1px solid #2a2a2e; border-radius: 16px; }
        .modal-header { border-bottom: 1px solid #2a2a2e; }
        .modal-footer { border-top: 1px solid #2a2a2e; }
        .dark-input { background: #0f0f11; border: 1px solid #2a2a2e; color: #e8eaed; border-radius: 10px; padding: 12px 16px; }
        .dark-input:focus { border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,0.15); color: #e8eaed; background: #0f0f11; }
        .btn-primary { background: linear-gradient(135deg, #667eea, #764ba2); border: none; }
        .btn-primary:hover { background: linear-gradient(135deg, #5a6fd6, #6a4298); }
    </style>
</head>
<body>

<div class="topbar">
    <a href="/" class="logo">
        <div class="logo-icon"><i class="bi bi-mortarboard-fill"></i></div>
        EduChatbot
    </a>
    <div class="d-flex gap-2"></div>
</div>

<div class="hero">
    <h1>Hệ thống hỏi đáp <span>thông minh</span></h1>
    <p>Tải lên tài liệu học tập, AI sẽ tự động phân tích và trả lời câu hỏi dựa trên nội dung. Hỗ trợ PDF, DOCX, PPTX.</p>
</div>

<div class="features">
    <div class="feat-pill"><i class="bi bi-scissors"></i> Tự động Chunk & Embed</div>
    <div class="feat-pill"><i class="bi bi-folder2-open"></i> Quản lý theo môn học</div>
    <div class="feat-pill"><i class="bi bi-list-check"></i> Xem tài liệu đã index</div>
    <div class="feat-pill"><i class="bi bi-chat-dots"></i> Chat ngữ cảnh tự nhiên</div>
    <div class="feat-pill"><i class="bi bi-quote"></i> Trích dẫn nguồn gốc</div>
    <div class="feat-pill"><i class="bi bi-shield-lock"></i> Giới hạn phạm vi tài liệu</div>
    <div class="feat-pill"><i class="bi bi-clock-history"></i> Lịch sử hội thoại</div>
</div>

<div class="cards-section">
    <h2><i class="bi bi-journal-bookmark me-2"></i>Môn học của tôi</h2>
    <div class="grid">
        <div class="card-nb card-nb-create" data-bs-toggle="modal" data-bs-target="#createModal">
            <div class="plus-icon"><i class="bi bi-plus-lg"></i></div>
            <div style="font-weight: 500;">Tạo môn học mới</div>
            <div style="font-size: 0.8rem; color: #9aa0a6;">Bắt đầu bằng cách thêm môn học và tải tài liệu lên</div>
        </div>

        @foreach (var subject in Model.OrderByDescending(s => s.Id))
        {
            var docCount = subject.Documents?.Count() ?? 0;
            var indexedCount = subject.Documents?.Count(d => d.IsIndexed) ?? 0;
            
            <a href="/Chat?subjectId=@subject.Id" class="card-nb">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="card-icon"><i class="bi bi-book"></i></div>
                </div>
                <div>
                    <div class="card-title">@subject.Name</div>
                    <div class="card-meta">
                        <span><i class="bi bi-tag"></i> @subject.Code</span>
                        <span><i class="bi bi-file-earmark"></i> @docCount tài liệu</span>
                        <span><i class="bi bi-database-check"></i> @indexedCount đã index</span>
                    </div>
                </div>
            </a>
        }
    </div>
</div>

<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <form asp-controller="Subjects" asp-action="Create" method="post" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle me-2 text-primary"></i>Tạo môn học mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-4">
                <div class="mb-3">
                    <label class="form-label small text-muted">Tên Môn Học</label>
                    <input type="text" name="Name" class="form-control dark-input" required placeholder="VD: Software Testing" autocomplete="off">
                </div>
                <div>
                    <label class="form-label small text-muted">Mã Môn</label>
                    <input type="text" name="Code" class="form-control dark-input" required placeholder="VD: SWT301" autocomplete="off">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-link text-muted text-decoration-none" data-bs-dismiss="modal">Hủy</button>
                <button type="submit" class="btn btn-primary rounded-pill px-4">Tạo mới</button>
            </div>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
